# ---------------------------------------------------------------------------
# W.Sign entegrasyon örnekleri — ortam değişkenleri
#
# Bu dosyayı ".env" olarak kopyalayın ve değerleri doldurun.
# HİÇBİR sır kod içine yazılmaz; tüm yapılandırma buradan okunur.
# ---------------------------------------------------------------------------

# W.Sign Redirect-Session REST API kök adresi (server-to-server çağrılar).
# Tarayıcı imzalama sayfası ayrıca https://sign.wsoft.tr/rs/{id} altında açılır.
WSIGN_API_BASE=https://api.sign.wsoft.tr

# Entegratör API anahtarınız (X-WSign-Api-Key başlığında gönderilir).
# Sandbox için "demo" entegratör anahtarı yakında yayınlanacaktır.
WSIGN_API_KEY=demo-REPLACE-ME

# Callback HMAC secret'ı — OPSİYONEL callback (webhook) POST'unu doğrulamak için.
# Birincil akış pull (sonucu GET ile çek) olduğundan yerel testte callback'i hiç
# kullanmadan ilerleyebilirsiniz. Entegratör kaydınıza özeldir (>= 32 byte).
# ASLA paylaşmayın.
WSIGN_CALLBACK_SECRET=demo-callback-secret-REPLACE-ME

# İmza tipi varsayılanı: imzalama formunda kullanıcı seçim yapmazsa bu kullanılır.
# Geçerli değerler (server ile ortak sabit kontrat):
#   CAdES-BES (vsy; damgasız) | CAdES-T (zaman damgalı) | CAdES-ESXLong (uzun dönemli)
#   XAdES-BES (damgasız)      | XAdES-T (zaman damgalı)
# CAdES-ESXLong = uzun dönemli imza (zaman damgası + sertifika zinciri + OCSP/CRL
# gömülü; EBYS/arşiv senaryoları için).
# Damgalı tipler (-T / ESXLong) için entegratör kaydınızda Kamu SM TSA tanımlı
# OLMALIDIR; değilse server 400 (TSA_NOT_CONFIGURED) döner ve örnek bunu
# kullanıcıya açıklar. Ayrıntı: docs/signature-profiles.md.
WSIGN_SIGNATURE_PROFILE=CAdES-BES

# Sonuç teslim modu: kullanıcı imzayı bitirince sonuç entegratöre nasıl ulaşsın?
#   redirect (varsayılan) → W.Sign kullanıcıyı successRedirectUrl'e 302 ile
#       döndürür; backend sonucu outbound GET ile çeker (pull). Yerelde tünelsiz.
#   post → W.Sign, successRedirectUrl'e tarayıcı-aracılı otomatik-POST formu ile
#       imzalı sonucu doğrudan gönderir (form-urlencoded; payload + HMAC imzası).
#       KAPALI SİSTEMLER için: backend dışarı çıkamıyor (pull yapamaz) ve içeri
#       webhook alamıyorsa, sonuç kullanıcının tarayıcısı üzerinden teslim edilir
#       (3D-Secure'un termUrl'e POST'u gibi). Ayrıntı: docs/delivery-modes.md.
WSIGN_RETURN_MODE=redirect

# Bu örnek uygulamanın kök adresi. callbackUrl ve successRedirectUrl buna göre
# üretilir.
#
# Yerel test (redirect + pull): TÜNEL GEREKMEZ. http://localhost:5000 kalabilir;
# yeter ki "localhost" host'u entegratör kaydınızın redirect allowlist'inde olsun
# (kullanıcının successRedirectUrl'e dönebilmesi için). Sonuç, backend'in
# W.Sign'a yaptığı outbound GET ile çekilir.
#
# Yerel/kapalı (PUBLIC_BASE_URL loopback — localhost/127.x/::1 — VEYA
# WSIGN_RETURN_MODE=post): örnekler `callbackUrl`'i HİÇ göndermez (webhook zaten
# ulaşamaz / gereksiz). Bu durumda entegratör kaydınızda callback allowlist'i
# gerekmez; yalnızca redirect allowlist'e "localhost" eklemeniz yeter.
#
# Opsiyonel callback'i (webhook) gerçekten denemek isterseniz: callback inbound
# POST olduğundan bu adres W.Sign'dan erişilebilir PUBLIC bir host olmalıdır —
# bir tünel (cloudflared / ngrok) URL'ini buraya verin. callbackUrl ancak host
# loopback DEĞİLKEN ve returnMode=post DEĞİLKEN gönderilir.
PUBLIC_BASE_URL=http://localhost:5000
