# ---------------------------------------------------------------------------
# W.Sign entegrasyon örnekleri — ortam değişkenleri
#
# Bu dosyayı ".env" olarak kopyalayın ve değerleri doldurun.
# HİÇBİR sır kod içine yazılmaz; tüm yapılandırma buradan okunur.
# ---------------------------------------------------------------------------

# W.Sign Redirect-Session REST API kök adresi (server-to-server çağrılar).
# Tarayıcı imzalama sayfası ayrıca https://sign.wsoft.tr/rs/{id} altında açılır.
WSIGN_API_BASE=https://api.sign.wsoft.tr

# Entegratör API anahtarınız (X-WSign-Api-Key başlığında gönderilir).
# Sandbox için "demo" entegratör anahtarı yakında yayınlanacaktır.
WSIGN_API_KEY=demo-REPLACE-ME

# Callback HMAC secret'ı — OPSİYONEL callback (webhook) POST'unu doğrulamak için.
# Birincil akış pull (sonucu GET ile çek) olduğundan yerel testte callback'i hiç
# kullanmadan ilerleyebilirsiniz. Entegratör kaydınıza özeldir (>= 32 byte).
# ASLA paylaşmayın.
WSIGN_CALLBACK_SECRET=demo-callback-secret-REPLACE-ME

# Bu örnek uygulamanın kök adresi. callbackUrl ve successRedirectUrl buna göre
# üretilir.
#
# Yerel test (redirect + pull): TÜNEL GEREKMEZ. http://localhost:5000 kalabilir;
# yeter ki "localhost" host'u entegratör kaydınızın redirect allowlist'inde olsun
# (kullanıcının successRedirectUrl'e dönebilmesi için). Sonuç, backend'in
# W.Sign'a yaptığı outbound GET ile çekilir.
#
# Opsiyonel callback'i de denemek isterseniz: callback inbound POST olduğundan
# bu adres W.Sign'dan erişilebilir olmalıdır — o durumda bir tünel
# (cloudflared / ngrok) URL'ini buraya verin.
PUBLIC_BASE_URL=http://localhost:5000
